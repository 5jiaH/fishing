{
  "name": "fishing",
  "version": "1.0.0",
  "private": true,
  "description": "Fishing monorepo",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "build:backend": "pnpm --filter @fishing/backend build",
    "build:frontend": "pnpm --filter @fishing/frontend build:weapp",
    "dev:backend": "pnpm --filter @fishing/backend start:dev",
    "dev:frontend": "pnpm --filter @fishing/frontend dev:weapp",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sqlite3",
      "bcrypt",
      "@swc/core",
      "esbuild"
    ]
  }
}
