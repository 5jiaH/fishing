.app-bar-root {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}

.app-bar-tagline {
  pointer-events: auto;
  width: 100%;
  box-sizing: border-box;
  padding: 16rpx 32rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 1.4;
  color: #0c4a6e;
  background: linear-gradient(
    90deg,
    rgba(224, 242, 254, 0.97),
    rgba(204, 251, 241, 0.95)
  );
  border-top: 1rpx solid rgba(14, 165, 233, 0.15);
  backdrop-filter: blur(12px);
}
